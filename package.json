{
  "name": "wtsapi_sessions",
  "version": "1.0.0",
  "description": "Microservice for processing whatsapp functions",
  "main": "index.js",
  "author": "Davyd Cardoso",
  "license": "MIT",
  "scripts": {
    "start": "ts-node src/worker.ts",
    "start:prod": "node dist/worker.js",
    "build": "rm -rf ./dist && tsc",
    "dev": "nodemon --exec ts-node src/index.ts",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org dc-sistemas --project simplix-wts-service ../../../../../../dist && sentry-cli sourcemaps upload --org dc-sistemas --project simplix-wts-service ../../../../../../dist"
  },
  "dependencies": {
    "axios": "^1.8.4",
    "dotenv": "^16.5.0",
    "ioredis": "^5.6.1",
    "nodemon": "^3.1.10",
    "qrcode-terminal": "^0.12.0",
    "rabbitmq-client": "^5.0.4",
    "whatsapp-web.js": "^1.27.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
